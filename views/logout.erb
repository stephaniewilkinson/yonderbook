<% content_for :title, "Log Out" %>
<% content_for :description, "Log out of your Yonderbook account." %>

<div class="max-w-md mx-auto">
  <div class="text-center mb-8">
    <h1 class="font-display text-3xl sm:text-4xl font-medium tracking-tight text-mauve-950 mb-3">
      Log Out
    </h1>
    <p class="text-lg text-mauve-700">
      Are you sure you want to log out?
    </p>
  </div>

  <% if flash['error'] %>
    <div class="bg-mauve-950/[.025] border border-mauve-300 text-mauve-950 px-4 py-3 rounded-xl mb-4">
      <p class="text-sm"><%= flash['error'] %></p>
    </div>
  <% end %>

  <form method="post" action="<%= rodauth.logout_path %>" class="space-y-4">
    <%= csrf_tag(rodauth.logout_path) %>

    <div class="flex gap-3">
      <button type="submit" class="flex-1 inline-flex items-center justify-center px-6 py-3 bg-mauve-950 text-white font-medium text-lg rounded-full hover:bg-mauve-900 transition-colors duration-200">
        Log Out
      </button>

      <a href="/home" class="flex-1 inline-flex items-center justify-center px-6 py-3 bg-mauve-950/10 text-mauve-950 font-medium text-lg rounded-full hover:bg-mauve-950/20 transition-colors duration-200">
        Cancel
      </a>
    </div>
  </form>
</div>
