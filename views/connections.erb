<% content_for :title, "Connections" %>
<% content_for :description, "Manage your connected reading services. Connect Goodreads to import your shelves and find free books." %>

<div class="max-w-6xl mx-auto">
  <!-- Header -->
  <div class="text-center mb-12">
    <h1 class="font-display text-5xl font-medium tracking-tight text-mauve-950 mb-4">Your Connections</h1>
    <p class="text-xl text-mauve-700">
      Manage your connected reading services and book platforms
    </p>
  </div>

  <div class="grid md:grid-cols-2 gap-6 mb-16">
    <!-- Goodreads Card -->
    <div class="rounded-xl bg-white/60 overflow-hidden flex flex-col">
      <div class="bg-white px-6 py-4 flex items-center justify-center">
        <a href="https://www.goodreads.com" target="_blank" rel="noopener noreferrer"><img src="/img/goodreads-logo.svg" alt="Goodreads" class="h-14"></a>
      </div>
      <div class="p-6 flex flex-col flex-1">
      <div class="mb-4">
        <% if @goodreads_connection %>
          <p class="text-sm text-mauve-700 font-medium flex items-center">
            <img src="/svg/checkmark-badge.svg" alt="Connected" class="w-4 h-4 mr-1">
            Connected
          </p>
        <% else %>
          <p class="text-sm text-mauve-600">Import your reading lists and shelves</p>
        <% end %>
      </div>

      <% if @goodreads_connection %>
        <div class="space-y-2 text-sm text-mauve-700 mb-4">
          <div class="flex items-center justify-between py-2 px-3 bg-mauve-950/[.025] rounded-lg">
            <span class="font-medium">User ID:</span>
            <span class="text-mauve-950 font-mono"><%= @goodreads_connection.goodreads_user_id %></span>
          </div>
          <div class="flex items-center justify-between py-2 px-3 bg-mauve-950/[.025] rounded-lg">
            <span class="font-medium">Connected:</span>
            <span class="text-mauve-950"><%= @goodreads_connection.connected_at.strftime('%B %d, %Y') %></span>
          </div>
          <% if @goodreads_connection.last_synced_at %>
            <div class="flex items-center justify-between py-2 px-3 bg-mauve-950/[.025] rounded-lg">
              <span class="font-medium">Last synced:</span>
              <span class="text-mauve-950"><%= @goodreads_connection.last_synced_at.strftime('%B %d, %Y') %></span>
            </div>
          <% end %>
        </div>

        <div class="mt-auto pt-4 border-t border-mauve-950/10 min-h-[7.5rem] flex flex-wrap items-center gap-3">
          <a href="/goodreads/shelves" class="inline-flex items-center px-6 py-3 bg-mauve-950 text-white font-medium rounded-full hover:bg-mauve-900 transition-colors duration-200">
            <img src="/svg/book.svg" alt="" class="w-5 h-5 mr-2 brightness-0 invert">
            View Your Shelves
          </a>
          <form method="post" action="/account/disconnect-goodreads" class="inline-block">
            <%= csrf_tag('/account/disconnect-goodreads') %>
            <button type="submit"
                    onclick="return confirm('Are you sure you want to disconnect your Goodreads account? This will remove your connection and delete your synced data.')"
                    class="inline-flex items-center px-6 py-3 bg-red-600 text-white font-medium rounded-full hover:bg-red-700 transition-colors duration-200 cursor-pointer">
              <img src="/svg/x.svg" alt="" class="w-5 h-5 mr-2 brightness-0 invert">
              Disconnect
            </button>
          </form>
        </div>
      <% else %>
        <div class="text-sm text-mauve-700 mb-6">
          <p class="leading-relaxed">
            Connect your Goodreads account to import your shelves, analyze your reading patterns, and find your books at libraries and through book trading.
          </p>
        </div>

        <div class="mt-auto pt-4 border-t border-mauve-950/10 min-h-[7.5rem] flex flex-col justify-center items-start">
          <a href="/goodreads" class="inline-flex items-center px-6 py-3 bg-mauve-950 text-white font-medium rounded-full hover:bg-mauve-900 transition-colors duration-200">
            <img src="/svg/star.svg" alt="" class="w-5 h-5 mr-2 brightness-0 invert">
            Connect Goodreads
          </a>
        </div>
      <% end %>
      </div>
    </div>

    <!-- BookMooch Card -->
    <div class="rounded-xl bg-white/60 overflow-hidden flex flex-col">
      <div class="bg-[#689a9b] px-6 py-4 flex items-center justify-center">
        <a href="https://bookmooch.com" target="_blank" rel="noopener noreferrer"><img src="/img/bookmooch-logo.gif" alt="BookMooch" class="h-14"></a>
      </div>
      <div class="p-6 flex flex-col flex-1">
      <div class="text-sm text-mauve-700 mb-6 space-y-3 leading-relaxed">
        <p>
          <a href="https://bookmooch.com" class="underline font-medium text-mauve-950 hover:text-mauve-700">BookMooch</a>
          is a community where readers trade physical books by mail. Add books from your want-to-read
          list to your BookMooch wishlist, and you'll get an email when someone has a copy to send you.
        </p>
        <p>
          You earn points by giving away books you've finished reading, then spend those points to
          request books from other readers. One point gets you a book within your country.
        </p>
        <p>
          Yonderbook can sync books from your Goodreads shelves straight to your BookMooch wishlist,
          so you don't have to add them one by one.
        </p>
      </div>

      <% if @goodreads_connection %>
        <p class="text-sm text-mauve-700 mb-4">
          You'll need a
          <a href="https://bookmooch.com/join" target="_blank" rel="noopener noreferrer" class="underline font-medium text-mauve-950 hover:text-mauve-700">BookMooch account</a>
          to sync your books. Choose a shelf below and enter your BookMooch credentials to get started.
        </p>
        <div class="mt-auto pt-4 border-t border-mauve-950/10 min-h-[7.5rem] flex flex-col justify-center items-start">
          <a href="/goodreads/shelves?mode=bookmooch" class="inline-flex items-center px-6 py-3 bg-mauve-950 text-white font-medium rounded-full hover:bg-mauve-900 transition-colors duration-200">
            <img src="/svg/refresh.svg" alt="" class="w-5 h-5 mr-2">
            Sync to BookMooch
          </a>
        </div>
      <% else %>
        <div class="mt-auto pt-4 border-t border-mauve-950/10 min-h-[7.5rem] flex flex-col justify-center items-start">
          <p class="text-sm text-mauve-600 flex items-center">
            <img src="/svg/info-circle.svg" alt="" class="w-4 h-4 mr-2">
            Connect Goodreads first to sync your shelves to BookMooch.
          </p>
        </div>
      <% end %>
      </div>
    </div>
  </div>

</div>
