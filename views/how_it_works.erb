<% content_for :title, "How It Works" %>
<% content_for :description, "Step-by-step guide to using Yonderbook. Connect your Goodreads account, select your library, and find free ebooks and audiobooks from your want-to-read list." %>

<% # HowTo Schema for this page %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Find Free Library Books from Your Goodreads List",
  "description": "Use Yonderbook to automatically find books from your Goodreads want-to-read list at your local library via Libby/OverDrive and through BookMooch book trading.",
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Create a Yonderbook account",
      "text": "Sign up with your email address. Verification takes just a few seconds.",
      "url": "https://yonderbook.com/sign-up"
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Connect your Goodreads account",
      "text": "Go to Connections and click 'Connect with Goodreads'. Authorize Yonderbook to access your reading lists.",
      "url": "https://yonderbook.com/connections"
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Select your library",
      "text": "Enter your zip code and we'll find libraries near you. Yonderbook works with thousands of libraries worldwide that use Libby/OverDrive.",
      "url": "https://yonderbook.com/connections/goodreads/shelves"
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "Choose a shelf to search",
      "text": "Pick any Goodreads shelf—want-to-read, to-read, or a custom shelf. Yonderbook will check availability for every book.",
      "url": "https://yonderbook.com/connections/goodreads/shelves"
    },
    {
      "@type": "HowToStep",
      "position": 5,
      "name": "Find free books",
      "text": "See which books are available at your library right now. Click through to borrow them in Libby or add unavailable books to your BookMooch wishlist."
    }
  ]
}
</script>

<div class="bg-white md:-mx-8 px-4 md:px-8 py-12 rounded-xl">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">How Yonderbook Works</h1>
    <p class="text-xl text-gray-600 mb-12">
      Turn your Goodreads want-to-read list into free books in 5 simple steps
    </p>

    <!-- Steps -->
    <div class="space-y-12">
      <!-- Step 1 -->
      <div class="flex gap-6">
        <div class="flex-shrink-0">
          <div class="w-12 h-12 bg-brand text-white rounded-full flex items-center justify-center font-bold text-xl">1</div>
        </div>
        <div class="flex-1">
          <h2 class="text-2xl font-semibold text-gray-900 mb-3">Create a Yonderbook account</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Sign up with your email address. We'll send you a quick verification email, and you'll be ready to go in under a minute.
          </p>
          <p class="text-sm text-gray-500">
            <strong>Why an account?</strong> Goodreads deprecated their API, so we need our own account system to provide reliable access to your book data.
          </p>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="flex gap-6">
        <div class="flex-shrink-0">
          <div class="w-12 h-12 bg-brand text-white rounded-full flex items-center justify-center font-bold text-xl">2</div>
        </div>
        <div class="flex-1">
          <h2 class="text-2xl font-semibold text-gray-900 mb-3">Connect your Goodreads account</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Go to the Connections page and click "Connect with Goodreads". You'll be redirected to Goodreads to authorize the connection. This lets us see your shelves and book lists.
          </p>
          <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
            <p class="text-sm text-amber-800">
              <strong>Note:</strong> You may need to click the connect button twice. The first click authorizes on Goodreads, the second completes the connection back to Yonderbook.
            </p>
          </div>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="flex gap-6">
        <div class="flex-shrink-0">
          <div class="w-12 h-12 bg-secondary text-white rounded-full flex items-center justify-center font-bold text-xl">3</div>
        </div>
        <div class="flex-1">
          <h2 class="text-2xl font-semibold text-gray-900 mb-3">Select your library</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Enter your zip code and we'll find libraries near you automatically. Most public libraries in the US, Canada, UK, and Australia use OverDrive for their digital catalog.
          </p>
          <p class="text-gray-600 leading-relaxed">
            Choose from the list of nearby libraries that offer OverDrive/Libby ebook lending.
          </p>
        </div>
      </div>

      <!-- Step 4 -->
      <div class="flex gap-6">
        <div class="flex-shrink-0">
          <div class="w-12 h-12 bg-secondary text-white rounded-full flex items-center justify-center font-bold text-xl">4</div>
        </div>
        <div class="flex-1">
          <h2 class="text-2xl font-semibold text-gray-900 mb-3">Choose a shelf to search</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Pick any of your Goodreads shelves—"want-to-read" is the most popular choice, but you can use any shelf including custom ones you've created.
          </p>
          <p class="text-gray-600 leading-relaxed">
            Yonderbook will check the availability of every book on that shelf at your selected library.
          </p>
        </div>
      </div>

      <!-- Step 5 -->
      <div class="flex gap-6">
        <div class="flex-shrink-0">
          <div class="w-12 h-12 bg-gradient-to-br from-brand to-secondary text-white rounded-full flex items-center justify-center font-bold text-xl">5</div>
        </div>
        <div class="flex-1">
          <h2 class="text-2xl font-semibold text-gray-900 mb-3">Find your free books!</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            See a list of books from your shelf that are available at your library right now. Click any title to open it directly in Libby where you can borrow it.
          </p>
          <p class="text-gray-600 leading-relaxed">
            For books that aren't available at your library, you can add them to your BookMooch wishlist with one click. BookMooch is a book trading community—you'll get an email when someone lists a copy you can get for free (just pay postage).
          </p>
        </div>
      </div>
    </div>

    <!-- What You Get Section -->
    <div class="mt-16 border-t border-gray-200 pt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">What else can you do with Yonderbook?</h2>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-3">Analyze your reading</h3>
          <p class="text-gray-600">
            See statistics about your reading habits: author gender breakdown, publication year distribution, your rating patterns, and more. Discover if you're reading as diversely as you think.
          </p>
        </div>

        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-3">Search any shelf</h3>
          <p class="text-gray-600">
            Not just want-to-read—search any Goodreads shelf including your "read" shelf to find books you might want to re-read, or custom shelves you've created.
          </p>
        </div>

        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-3">Multiple libraries</h3>
          <p class="text-gray-600">
            Have library cards for multiple systems? Search different libraries to maximize your chances of finding available copies.
          </p>
        </div>

        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-3">BookMooch integration</h3>
          <p class="text-gray-600">
            Automatically add books from your Goodreads list to your BookMooch wishlist. Get notified when books you want become available for trading.
          </p>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-12 bg-gradient-to-r from-brand to-secondary rounded-xl p-8 text-center">
      <h2 class="text-2xl font-bold text-white mb-4">Ready to find your next free book?</h2>
      <p class="text-gray-100 mb-6">Create your account and start searching your library in under 2 minutes.</p>
      <a href="/sign-up" class="inline-flex items-center px-6 py-3 bg-white text-brand font-semibold rounded-lg hover:bg-gray-100 transition-colors">
        Get Started Free
      </a>
    </div>
  </div>
</div>
