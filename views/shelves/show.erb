<h5 class="text-center text-lg font-medium mt-8 text-mauve-950">
  Rating Distribution
</h5>
<div class="w-full rounded-xl bg-mauve-950/[.025] border border-mauve-950/10">
  <div class="px-6 py-4 bg-mauve-950 text-white rounded-t-xl">
    <div class="text-center">
      <div class="text-sm font-medium opacity-90">Shelf Average</div>
      <div class="text-2xl font-display font-medium">
        <%= @ratings.reject { |k, v| k == 0 }.sum { |k, v| k * v }.fdiv(@ratings.reject { |k, v| k == 0 }.values.sum).round(2) %> ⭐
      </div>
    </div>
  </div>
  <div class="h-96 p-6">
    <canvas id="ratingsBarChart"></canvas>
  </div>
</div>

