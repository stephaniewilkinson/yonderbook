<% content_for :title, "Loading #{@shelf_name}" %>

<div class="max-w-4xl mx-auto mb-8 mt-16">
  <div class="text-center">
    <h3 class="font-display text-2xl font-medium text-mauve-950 mb-4">Loading your <em><%= @shelf_name %></em> shelf</h3>

    <div class="flex justify-center mb-6">
      <div class="relative">
        <div class="w-20 h-20 border-4 border-mauve-200 border-t-mauve-950 rounded-full animate-spin"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <svg class="w-8 h-8 text-mauve-950" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
          </svg>
        </div>
      </div>
    </div>

    <p class="text-mauve-700 mb-2">Fetching books from Goodreads...</p>
    <p class="text-sm text-mauve-500">This may take a moment for large shelves.</p>
  </div>
</div>

<script>
(function() {
  var polling = setInterval(function() {
    fetch('/import-status')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.ready) {
          clearInterval(polling);
          window.location.reload();
        }
      })
      .catch(function() {});
  }, 2000);
})();
</script>
