<% content_for :title, "Find Your Library" %>
<% content_for :description, "Enter your zip code to find libraries near you. Search for free ebooks and audiobooks from your Goodreads list via Libby/OverDrive." %>

<div class="max-w-4xl mx-auto mb-8">
  <div class="text-center">
    <h3 class="font-display text-2xl font-medium text-mauve-950 mb-4">Step 2</h3>
    <div class="w-full bg-mauve-200 rounded-full h-2 mb-4">
      <div class="bg-mauve-950 h-2 rounded-full w-1/2"></div>
    </div>
    <h5 class="text-xl font-medium text-mauve-700">Find a library near you</h5>
  </div>
</div>

<div class="max-w-2xl mx-auto">
  <div class="rounded-xl bg-mauve-950/[.025] p-6">
    <form action="/libraries" method="post" autocomplete="on">
      <div class="mb-6">
        <label for="zipcode" class="block text-sm font-medium text-mauve-950 mb-2">Enter your zip code:</label>
        <input type="text"
               id="zipcode"
               name="zipcode"
               inputmode="numeric"
               autofocus
               autocomplete="postal-code"
               pattern="[0-9]{5}"
               maxlength="5"
               class="w-full px-3 py-2 border border-mauve-300 rounded-xl bg-white focus:ring-2 focus:ring-mauve-500 focus:border-mauve-500"
               placeholder="12345">
      </div>
      <button class="w-full inline-flex items-center justify-center px-6 py-3 bg-mauve-950 hover:bg-mauve-900 text-white font-medium text-lg rounded-full transition-colors duration-200"
              type="submit"
              name="action">
        <img src="/svg/location-marker.svg" alt="Location" class="w-5 h-5 mr-2">
        Find a library
      </button>
    </form>
  </div>
</div>
