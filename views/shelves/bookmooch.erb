<% content_for :title, "Add to BookMooch Wishlist" %>
<% content_for :description, "Add books from your Goodreads shelf to your BookMooch wishlist. Get notified when books become available for free book trading." %>

<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <div class="flex items-center mb-6">
      <div class="flex-shrink-0 mr-4">
        <svg class="w-12 h-12 text-mauve-950" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
        </svg>
      </div>
      <div>
        <h4 class="font-display text-2xl font-medium text-mauve-950 mb-2">Receive books</h4>
        <p class="text-mauve-700">Add these books to your Bookmooch wishlist, so Bookmooch will email you when they become available to mooch. Then get them by mail!</p>
      </div>
    </div>

    <div class="rounded-xl bg-mauve-950 overflow-hidden">
      <div class="p-4 bg-mauve-900">
        <img src="http://i.bookmooch.com/images/bookmooch_logo.gif" alt="BookMooch Logo" class="h-12">
      </div>
      <div class="p-6">
        <h5 class="text-xl font-display font-medium text-white mb-4">Mooch these books</h5>
        <p class="text-mauve-300 mb-4">Enter your credentials to log into Bookmooch.com.</p>

        <div class="text-sm text-mauve-300 mb-6 space-y-1">
          <p><span class="text-white font-medium"><%= @new_count %></span> new books to add</p>
          <% if @skip_count.positive? %>
            <p><span class="text-white font-medium"><%= @skip_count %></span> already on your wishlist (will be skipped)</p>
          <% end %>
          <% if @no_isbn_count.positive? %>
            <p><span class="text-white font-medium"><%= @no_isbn_count %></span> missing ISBN (can't match on BookMooch)</p>
          <% end %>
        </div>

        <form action="bookmooch" method="post">
          <div class="space-y-4 mb-6">
            <div>
              <label for="username" class="block text-sm font-medium text-mauve-300 mb-2">
                BookMooch Username:
              </label>
              <input type="text"
                     id="username"
                     name="username"
                     placeholder="Enter your BookMooch username"
                     autocomplete="username"
                     class="w-full px-3 py-2 bg-mauve-900 border border-mauve-700 rounded-xl text-white placeholder-mauve-500 focus:ring-mauve-400 focus:border-mauve-400">
            </div>
            <div>
              <label for="password" class="block text-sm font-medium text-mauve-300 mb-2">Password:</label>
              <input type="password"
                     id="password"
                     name="password"
                     autocomplete="current-password"
                     class="w-full px-3 py-2 bg-mauve-900 border border-mauve-700 rounded-xl text-white placeholder-mauve-500 focus:ring-mauve-400 focus:border-mauve-400">
            </div>
          </div>

          <% if @skip_count.positive? %>
          <div class="flex items-center mb-4">
            <input type="checkbox" id="reimport" name="reimport" value="1"
                   class="w-4 h-4 rounded border-mauve-600 bg-mauve-800 text-mauve-400 focus:ring-mauve-500">
            <label for="reimport" class="ml-2 text-sm text-mauve-400">
              Re-import all books (send all <%= @skip_count + @new_count %> instead of just <%= @new_count %> new)
            </label>
          </div>
          <% end %>

          <button class="authenticate-btn w-full inline-flex items-center justify-center px-6 py-3 bg-white text-mauve-950 font-medium rounded-full hover:bg-mauve-100 transition-colors duration-200"
                  type="submit"
                  name="action">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
            </svg>
            Authenticate
          </button>

          <button class="sending-btn hidden w-full inline-flex items-center justify-center px-6 py-3 bg-mauve-300 text-mauve-950 font-medium rounded-full"
                  type="button"
                  disabled>
            <svg class="w-5 h-5 mr-2 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Sending to BookMooch...
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
  var oldbutton = document.getElementsByClassName('authenticate-btn')[0];
  var newbutton = document.getElementsByClassName('sending-btn')[0];

  oldbutton.onclick = function(){
    newbutton.classList.remove('hidden');
    oldbutton.classList.add('hidden');
  };
</script>
