<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) ? "#{content_for(:title)} | Yonderbook" : "Yonderbook | Goodreads Libby Integration — Find Your Books Free at the Library" %></title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= content_for(:description) || "Goodreads Libby integration made easy. Automatically check which books on your Goodreads want-to-read shelf are available free at your library through Libby and OverDrive." %>">
    <meta name="keywords" content="Goodreads, Libby, OverDrive, BookMooch, free books, library ebooks, book trading, want to read, reading list, free audiobooks, library catalog search">

    <!-- Canonical URL -->
    <link rel="canonical" href="<%= @canonical_url || "https://yonderbook.com#{request.path}" %>">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= @canonical_url || "https://yonderbook.com#{request.path}" %>">
    <meta property="og:title" content="<%= content_for(:og_title) || content_for(:title) || "Yonderbook | Goodreads Libby Integration — Find Your Books Free at the Library" %>">
    <meta property="og:description" content="<%= content_for(:og_description) || content_for(:description) || "Goodreads Libby integration made easy. Automatically find which books on your want-to-read shelf are available free at your library." %>">
    <meta property="og:image" content="<%= @og_image || "https://yonderbook.com/img/yonderbook.png" %>">
    <meta property="og:site_name" content="Yonderbook">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="<%= @canonical_url || "https://yonderbook.com#{request.path}" %>">
    <meta property="twitter:title" content="<%= content_for(:twitter_title) || content_for(:og_title) || content_for(:title) || "Yonderbook | Goodreads Libby Integration" %>">
    <meta property="twitter:description" content="<%= content_for(:twitter_description) || content_for(:og_description) || content_for(:description) || "Goodreads Libby integration made easy. Find your want-to-read books free at your library." %>">
    <meta property="twitter:image" content="<%= @twitter_image || @og_image || "https://yonderbook.com/img/yonderbook.png" %>">

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/svg/favicon.svg?v=2">

    <!-- Preload critical resources for faster loading -->
    <%= preload_assets_link_tags(:css) %>

    <!-- Google Fonts: Inter + Mona Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Mona+Sans:ital,wdth,wght@0,112.5,200..900;1,112.5,200..900&display=swap" rel="stylesheet">

    <!-- Tailwind CSS with Mauve Theme -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'mauve': {
                50: '#fbfafb',
                100: '#f4f2f4',
                200: '#e8e4e8',
                300: '#d6d0d6',
                400: '#afa7af',
                500: '#857a86',
                600: '#6a6169',
                700: '#575057',
                800: '#3e383e',
                900: '#312c31',
                '950': '#211d21'
              }
            },
            fontFamily: {
              'display': ['"Mona Sans"', 'sans-serif'],
              'sans': ['Inter', 'system-ui', 'sans-serif']
            },
            animation: {
              'fade-in-up': 'fadeInUp 0.8s ease-out forwards',
              'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
              'bounce-subtle': 'bounceSubtle 2s infinite ease-in-out',
            },
            keyframes: {
              fadeInUp: {
                '0%': { opacity: '0', transform: 'translateY(20px)' },
                '100%': { opacity: '1', transform: 'translateY(0)' },
              },
              bounceSubtle: {
                '0%, 100%': { transform: 'translateY(0)' },
                '50%': { transform: 'translateY(-2px)' },
              }
            }
          }
        }
      }
    </script>
    <style>
      .glass-panel {
        @apply bg-white/40 backdrop-blur-xl border border-white/40 shadow-lg;
      }
      .glass-nav {
         @apply bg-mauve-100/70 backdrop-blur-md border-b border-white/20 shadow-sm transition-all duration-300;
      }
      .bg-gradient-radial {
        background-image: radial-gradient(circle at 50% 0%, var(--tw-gradient-stops));
      }
    </style>

    <%= assets(:css) %>

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Yonderbook",
      "url": "https://yonderbook.com",
      "description": "Turn your Goodreads want-to-read list into free books. Find your books at libraries via Libby/OverDrive and through BookMooch book trading.",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Web",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5",
        "ratingCount": "1"
      },
      "featureList": [
        "Import Goodreads shelves",
        "Find books at local libraries",
        "Check Libby/OverDrive availability",
        "BookMooch integration",
        "Reading analytics",
        "Author diversity tracking"
      ]
    }
    </script>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Yonderbook",
      "url": "https://yonderbook.com",
      "logo": "https://yonderbook.com/svg/book-nav.svg",
      "sameAs": []
    }
    </script>

    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=UA-96996170-1"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'UA-96996170-1');
    </script>

    <!-- Pixel Code - https://app.tinyanalytics.io/ -->
    <script defer src="https://app.tinyanalytics.io/pixel/KyJ6JipBW9No4r00"></script>
    <!-- END Pixel Code -->
  </head>

  <body class="flex flex-col min-h-screen bg-gradient-radial from-white via-mauve-50 to-mauve-100 font-sans antialiased text-mauve-950/90 selection:bg-mauve-200 selection:text-mauve-950">
    <main class="flex-1">
      <nav class="sticky top-0 z-50 glass-nav group">
        <div class="max-w-2xl md:max-w-3xl lg:max-w-7xl mx-auto px-6 lg:px-10">
          <div class="flex justify-between items-center h-16">
            <!-- Logo -->
            <div class="flex-shrink-0">
              <a href="/" class="flex items-center space-x-2 text-2xl font-display font-medium text-mauve-950 tracking-tight group-hover:text-mauve-800 transition-colors duration-300">
                <img src="/svg/book-nav.svg" alt="Book" class="w-8 h-8 group-hover:scale-105 transition-transform duration-300">
                <span>Yonderbook</span>
              </a>
            </div>

            <!-- Desktop Navigation -->
            <div class="hidden md:block">
              <div class="flex items-center space-x-1">
                <a href="/about"
                   class="px-4 py-2 text-sm font-medium text-mauve-950 hover:bg-mauve-950/10 rounded-full transition-colors duration-200">
                  About
                </a>

                <% if rodauth.logged_in? %>
                  <a href="/home"
                     class="px-4 py-2 text-sm font-medium text-mauve-950 hover:bg-mauve-950/10 rounded-full transition-colors duration-200">
                    Home
                  </a>
                  <% if @user&.goodreads_connected? %>
                  <a href="/connections/goodreads/shelves"
                     class="px-4 py-2 text-sm font-medium text-mauve-950 hover:bg-mauve-950/10 rounded-full transition-colors duration-200">
                    Shelves
                  </a>
                  <% end %>
                  <a href="/connections"
                     class="px-4 py-2 text-sm font-medium text-mauve-950 hover:bg-mauve-950/10 rounded-full transition-colors duration-200">
                    Connections
                  </a>
                  <a href="/account"
                     class="px-4 py-2 text-sm font-medium text-mauve-950 hover:bg-mauve-950/10 rounded-full transition-colors duration-200">
                    Account
                  </a>
                <% else %>
                  <a href="/authenticate"
                     class="px-4 py-2 text-sm font-medium text-mauve-950 hover:bg-mauve-950/10 rounded-full transition-colors duration-200">
                    Login
                  </a>
                  <a href="/sign-up"
                     class="px-5 py-2.5 ml-3 text-sm font-medium text-white bg-gradient-to-r from-mauve-800 to-mauve-950 hover:from-mauve-700 hover:to-mauve-900 rounded-full shadow-md hover:shadow-lg transition-all duration-300 hover:-translate-y-0.5 animate-bounce-subtle inline-block">
                    Sign Up
                  </a>
                <% end %>
              </div>
            </div>

            <!-- Mobile menu button -->
            <div class="md:hidden">
              <button type="button"
                      class="mobile-menu-button p-2 text-mauve-950 hover:bg-mauve-950/10 rounded-full focus:outline-none"
                      onclick="toggleMobileMenu()">
                <img src="/svg/menu.svg" alt="Menu" class="block h-6 w-6">
              </button>
            </div>
          </div>

          <!-- Mobile Navigation -->
          <div class="mobile-menu hidden md:hidden">
            <div class="px-2 pt-2 pb-3 space-y-1">
              <a href="/about"
                 class="block px-4 py-2 text-base font-medium text-mauve-950 hover:bg-mauve-950/10 rounded-full transition-colors duration-200">
                About
              </a>

              <% if rodauth.logged_in? %>
                <a href="/home"
                   class="block px-4 py-2 text-base font-medium text-mauve-950 hover:bg-mauve-950/10 rounded-full transition-colors duration-200">
                  Home
                </a>
                <% if @user&.goodreads_connected? %>
                <a href="/connections/goodreads/shelves"
                   class="block px-4 py-2 text-base font-medium text-mauve-950 hover:bg-mauve-950/10 rounded-full transition-colors duration-200">
                  Shelves
                </a>
                <% end %>
                <a href="/connections"
                   class="block px-4 py-2 text-base font-medium text-mauve-950 hover:bg-mauve-950/10 rounded-full transition-colors duration-200">
                  Connections
                </a>
                <a href="/account"
                   class="block px-4 py-2 text-base font-medium text-mauve-950 hover:bg-mauve-950/10 rounded-full transition-colors duration-200">
                  Account
                </a>
              <% else %>
                <a href="/authenticate"
                   class="block px-4 py-2 text-base font-medium text-mauve-950 hover:bg-mauve-950/10 rounded-full transition-colors duration-200">
                  Login
                </a>
                <a href="/sign-up"
                   class="block px-4 py-2 text-base font-medium text-white bg-mauve-950 rounded-full transition-colors duration-200">
                  Sign Up
                </a>
              <% end %>
            </div>
          </div>
        </div>
      </nav>

      <%= partial 'flash_notifications' %>

      <div class="max-w-2xl md:max-w-3xl lg:max-w-7xl mx-auto px-6 lg:px-10 py-16">
        <%= yield %>
      </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-mauve-950/5 bg-gradient-to-b from-transparent to-mauve-100/50 mt-12">
      <div class="max-w-2xl md:max-w-3xl lg:max-w-7xl mx-auto px-6 lg:px-10 py-16">
        <div class="flex flex-col md:flex-row items-center justify-between gap-8">
          <a href="/" class="flex items-center space-x-2 text-lg font-display font-medium text-mauve-950 tracking-tight hover:opacity-80 transition-opacity">
            <img src="/svg/book-nav.svg" alt="Book" class="w-6 h-6">
            <span>Yonderbook</span>
          </a>
          <nav class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4 text-sm font-medium text-mauve-600">
            <a href="/about" class="hover:text-mauve-950 transition-colors duration-200">About</a>
            <a href="/how-it-works" class="hover:text-mauve-950 transition-colors duration-200">How It Works</a>
            <a href="/faq" class="hover:text-mauve-950 transition-colors duration-200">FAQ</a>
          </nav>
          <p class="text-sm text-mauve-500">&copy; <%= Time.now.year %> Yonderbook</p>
        </div>
      </div>
    </footer>

    <!-- Custom JavaScript -->
    <script>
      // Mobile menu toggle function
      function toggleMobileMenu() {
        var mobileMenu = document.querySelector('.mobile-menu');
        mobileMenu.classList.toggle('hidden');
      }

      // Auto-dismiss flash messages with fade out
      document.addEventListener('DOMContentLoaded', function() {
        ['flash-error', 'flash-notice'].forEach(function(id) {
          var el = document.getElementById(id);
          if (el) {
            setTimeout(function() { el.style.opacity = '0'; }, 3500);
            setTimeout(function() { el.remove(); }, 4000);
          }
        });
      });
    </script>

    <!--Start of Tawk.to Script-->
    <script type="text/javascript">
    var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
    (function(){
    var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
    s1.async=true;
    s1.src='https://embed.tawk.to/68d6960634eabc19222ddc76/1j633k22v';
    s1.charset='UTF-8';
    s1.setAttribute('crossorigin','*');
    s0.parentNode.insertBefore(s1,s0);
    })();
    </script>
    <!--End of Tawk.to Script-->
  </body>
</html>
