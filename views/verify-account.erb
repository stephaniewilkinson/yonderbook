<% content_for :title, "Verify Your Account" %>
<% content_for :description, "Verify your email address to complete your Yonderbook account setup." %>

<div class="max-w-md mx-auto">
  <div class="text-center mb-8">
    <h1 class="font-display text-3xl sm:text-4xl font-medium tracking-tight text-mauve-950 mb-3">
      Verify Your Account
    </h1>
    <p class="text-lg text-mauve-700">
      Click the button below to verify your email address
    </p>
  </div>

  <% if rodauth.field_error('key') %>
    <div class="bg-mauve-950/[.025] border border-mauve-300 text-mauve-950 px-4 py-3 rounded-xl mb-4">
      <p class="text-sm"><%= rodauth.field_error('key') %></p>
    </div>
  <% end %>

  <form method="post" action="<%= rodauth.verify_account_path %>" class="space-y-4">
    <%= csrf_tag(rodauth.verify_account_path) %>
    <input type="hidden" name="<%= rodauth.verify_account_key_param %>" value="<%= rodauth.param(rodauth.verify_account_key_param) %>">

    <div class="pt-2">
      <button type="submit" class="w-full inline-flex items-center justify-center px-6 py-3 bg-mauve-950 text-white font-medium text-lg rounded-full hover:bg-mauve-900 transition-colors duration-200">
        Verify Account
      </button>
    </div>
  </form>
</div>
