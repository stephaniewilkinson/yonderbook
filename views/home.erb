<% content_for :title, "Home" %>
<% content_for :description, "Your Yonderbook dashboard. Connect your reading services and start finding free books at your library and through book trading." %>

<!-- Welcome Section -->
<div class="mb-16 animate-fade-in-up">
  <div class="text-center relative">
    <div class="absolute inset-0 bg-gradient-to-b from-white/60 to-transparent blur-3xl -z-10 rounded-full w-3/4 mx-auto hidden md:block"></div>
    <h1 class="font-display text-4xl sm:text-5xl font-semibold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-mauve-950 via-mauve-800 to-mauve-950 mb-5 leading-tight">
      Welcome to Yonderbook
    </h1>
    <p class="text-xl text-mauve-600 mb-8 max-w-2xl mx-auto font-light">
      You're all set up. Let's connect your reading services to start finding your books for free.
    </p>
  </div>
</div>

<!-- Services Section -->
<div class="grid md:grid-cols-2 gap-8 mb-12 animate-fade-in-up" style="animation-delay: 0.1s;">
  <!-- Goodreads Service -->
  <div class="glass-panel rounded-2xl p-8 hover:-translate-y-1 hover:shadow-2xl hover:shadow-mauve-900/10 transition-all duration-400 group relative overflow-hidden">
    <div class="absolute top-0 right-0 w-32 h-32 bg-mauve-200/40 rounded-full blur-3xl -mr-16 -mt-16 transition-transform group-hover:scale-150 duration-700"></div>
    
    <div class="flex items-start space-x-5 relative z-10">
      <div class="flex-shrink-0">
        <div class="w-14 h-14 bg-gradient-to-br from-mauve-800 to-mauve-950 rounded-2xl flex items-center justify-center shadow-inner group-hover:shadow-[0_0_20px_rgba(49,44,49,0.3)] transition-shadow duration-300">
          <img src="/img/goodreads-icon.png" alt="Goodreads" class="w-8 h-8 filter brightness-0 invert opacity-90 group-hover:opacity-100 transition-opacity">
        </div>
      </div>
      <div class="flex-1">
        <h3 class="text-xl font-semibold text-mauve-950 mb-2">Goodreads</h3>
        <p class="text-mauve-600 mb-5 leading-relaxed text-sm">Import your reading lists, want-to-read books, and analyze your reading patterns.</p>

        <% if @user.goodreads_connected? %>
          <div class="flex items-center space-x-2.5 mb-5 px-3 py-1.5 bg-green-50/50 border border-green-100 rounded-full inline-flex">
            <div class="relative flex h-2.5 w-2.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
            </div>
            <span class="text-xs font-semibold text-green-700 uppercase tracking-wide">Connected</span>
          </div>
          <a href="/connections/goodreads/shelves" class="inline-flex items-center px-5 py-2.5 bg-mauve-950 text-white rounded-xl hover:bg-mauve-900 shadow-md hover:shadow-lg transition-all duration-300 font-medium text-sm group/btn">
            <img src="/svg/book.svg" alt="Shelves" class="w-4 h-4 mr-2.5 filter brightness-0 invert opacity-80 group-hover/btn:opacity-100">
            View Your Shelves
          </a>
        <% else %>
          <div class="flex items-center space-x-2.5 mb-5 px-3 py-1.5 bg-mauve-100/50 border border-mauve-200/50 rounded-full inline-flex">
            <div class="w-2.5 h-2.5 bg-mauve-300 rounded-full"></div>
            <span class="text-xs font-semibold text-mauve-600 uppercase tracking-wide">Not connected</span>
          </div>
          <a href="/connections/goodreads" class="inline-flex items-center px-5 py-2.5 bg-gradient-to-r from-mauve-900 to-mauve-950 text-white rounded-xl hover:from-mauve-800 hover:to-mauve-900 shadow-md hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 font-medium text-sm focus:outline-none focus:ring-2 focus:ring-mauve-500 focus:ring-offset-2">
            <img src="/img/goodreads-icon.png" alt="Connect" class="w-4 h-4 mr-2.5 filter brightness-0 invert opacity-90">
            Connect Goodreads
            <img src="/svg/external-link.svg" alt="External link" class="w-4 h-4 ml-2.5 opacity-60">
          </a>
        <% end %>
      </div>
    </div>
  </div>

</div>
