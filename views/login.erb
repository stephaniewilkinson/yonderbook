<% content_for :title, "Log In" %>
<% content_for :description, "Log in to your Yonderbook account to access your reading tools and find free books." %>

<div class="mx-auto w-full max-w-sm">
  <h2 class="text-2xl font-bold tracking-tight text-mauve-950">Sign in to your account</h2>

  <% if rodauth.field_error('email') || rodauth.field_error('password') %>
    <div class="mt-6 bg-mauve-950/[.025] border border-mauve-300 text-mauve-950 px-4 py-3 rounded-lg">
      <% if rodauth.field_error('email') %>
        <p class="text-sm"><%= rodauth.field_error('email') %></p>
      <% end %>
      <% if rodauth.field_error('password') %>
        <p class="text-sm"><%= rodauth.field_error('password') %></p>
      <% end %>
    </div>
  <% end %>

  <form method="post" action="<%= rodauth.login_path %>" class="mt-8 grid grid-cols-1 gap-8" id="password-login-form">
    <%= csrf_tag(rodauth.login_path) %>

    <div>
      <label for="email" class="block text-sm font-medium text-mauve-950">Email</label>
      <input id="email" type="email" name="email" required autocomplete="email" value="<%= rodauth.param('email') %>" class="mt-2 block w-full rounded-md border border-mauve-300 bg-white px-3 py-1.5 text-mauve-950 placeholder:text-mauve-400 focus:border-mauve-500 focus:ring-2 focus:ring-mauve-500 sm:text-sm">
    </div>

    <div>
      <label for="password" class="block text-sm font-medium text-mauve-950">Password</label>
      <input id="password" type="password" name="password" required autocomplete="current-password" class="mt-2 block w-full rounded-md border border-mauve-300 bg-white px-3 py-1.5 text-mauve-950 placeholder:text-mauve-400 focus:border-mauve-500 focus:ring-2 focus:ring-mauve-500 sm:text-sm">
    </div>

    <div class="flex items-center justify-between">
      <a href="<%= rodauth.reset_password_request_path %>" class="text-sm font-semibold text-mauve-700 hover:text-mauve-950">Forgot password?</a>
    </div>

    <button type="submit" class="w-full rounded-md bg-mauve-950 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-mauve-900 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-mauve-600">Sign in</button>
  </form>

  <div class="mt-8 flex items-center gap-x-4">
    <div class="flex-1 border-t border-mauve-300"></div>
    <span class="text-sm text-mauve-500">Or</span>
    <div class="flex-1 border-t border-mauve-300"></div>
  </div>

  <form method="post" action="<%= rodauth.email_auth_request_path %>" class="mt-8" id="magic-link-form">
    <%= csrf_tag(rodauth.email_auth_request_path) %>
    <input type="hidden" name="email" id="magic-link-email">
    <button type="submit" onclick="var e=document.getElementById('email');if(!e.value||!e.validity.valid){e.classList.add('border-red-500','ring-2','ring-red-200');e.focus();return false;}e.classList.remove('border-red-500','ring-2','ring-red-200');document.getElementById('magic-link-email').value=e.value" class="flex w-full items-center justify-center gap-2 rounded-md border border-mauve-300 bg-white px-3 py-2 text-sm font-semibold text-mauve-950 shadow-sm hover:bg-mauve-50">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
      </svg>
      Email me a login link
    </button>
  </form>

  <p class="mt-8 text-sm text-mauve-500">
    Don't have an account?
    <a href="/sign-up" class="font-semibold text-mauve-700 hover:text-mauve-950">Sign up</a>
  </p>
</div>
