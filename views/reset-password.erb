<% content_for :title, "Create New Password" %>
<% content_for :description, "Create a new password for your Yonderbook account." %>

<div class="max-w-md mx-auto">
  <div class="text-center mb-8">
    <h1 class="font-display text-3xl sm:text-4xl font-medium tracking-tight text-mauve-950 mb-3">
      Create New Password
    </h1>
    <p class="text-lg text-mauve-700">
      Enter your new password below
    </p>
  </div>

  <% if rodauth.field_error('password') %>
    <div class="bg-mauve-950/[.025] border border-mauve-300 text-mauve-950 px-4 py-3 rounded-xl mb-4">
      <p class="text-sm"><%= rodauth.field_error('password') %></p>
    </div>
  <% end %>

  <form method="post" action="<%= rodauth.reset_password_path %>" class="space-y-4">
    <%= csrf_tag(rodauth.reset_password_path) %>
    <input type="hidden" name="<%= rodauth.reset_password_key_param %>" value="<%= rodauth.param(rodauth.reset_password_key_param) %>">

    <div>
      <label for="password" class="block text-sm font-medium text-mauve-950 mb-1">
        New Password
      </label>
      <input type="password"
             name="password"
             id="password"
             autocomplete="new-password"
             class="w-full px-4 py-2 border border-mauve-300 rounded-xl bg-white focus:ring-2 focus:ring-mauve-500 focus:border-mauve-500 transition-all duration-200"
             required>
    </div>

    <div class="pt-2">
      <button type="submit" class="w-full inline-flex items-center justify-center px-6 py-3 bg-mauve-950 text-white font-medium text-lg rounded-full hover:bg-mauve-900 transition-colors duration-200">
        Reset Password
      </button>
    </div>
  </form>
</div>
