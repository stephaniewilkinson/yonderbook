<% content_for :title, "BookMooch Results" %>
<% content_for :description, "See which books were added to your BookMooch wishlist. You'll get email notifications when these books become available for trading." %>

<%
  # Build summary lines for header
  summary_lines = []
  unless @books_added.empty?
    summary_lines << "Added #{@books_added.size} books to your BookMooch wishlist."
    summary_lines << "Couldn't add #{@books_failed.size} books." if @books_failed.size > 0
    summary_lines << "#{@books_failed_no_isbn.size} books could not be matched (missing ISBN)." if @books_failed_no_isbn.size > 0
  end
  summary_lines << "Skipped #{@skipped_count} books already on your wishlist." if @skipped_count > 0

  header = {
    title: @books_added.empty? ? 'No Books Added' : 'Success!',
    summary_lines: @books_added.empty? ? nil : summary_lines
  }

  tabs = [
    {
      label: 'Added',
      title: "These #{@books_added.size} books are now on your wishlist",
      color: 'mauve',
      count: @books_added.size,
      empty_message: 'No books were added to your wishlist.',
      books: @books_added.map do |book|
        {
          image: book[:image_url],
          title: book[:title],
          author: book[:author] || 'Unknown Author',
          isbn: book[:bookmooch_isbn],
          button: book[:bookmooch_isbn] ? {
            url: "https://bookmooch.com/m/detail/#{book[:bookmooch_isbn]}",
            label: 'View on BookMooch',
            class: 'bg-mauve-950 hover:bg-mauve-900'
          } : nil
        }
      end
    },
    {
      label: 'Not on BookMooch',
      title: "#{@books_failed.size} Books Not in BookMooch Catalog",
      color: 'mauve',
      count: @books_failed.size,
      description: "BookMooch doesn't have these books listed in its catalog. You can try adding them manually on BookMooch using a different edition or ISBN.",
      empty_message: 'All books were found on BookMooch!',
      books: @books_failed.map do |book|
        {
          image: book[:image_url],
          title: book[:title],
          author: book[:author] || 'Unknown Author'
        }
      end
    },
    {
      label: 'Missing ISBN',
      title: "#{@books_failed_no_isbn.size} Books Missing ISBN",
      color: 'mauve',
      count: @books_failed_no_isbn.size,
      description: "These books don't have ISBN information in Goodreads, so we can't look them up on BookMooch. You can add ISBNs to these books in Goodreads, then re-import.",
      empty_message: 'All books on your shelf have ISBNs!',
      books: @books_failed_no_isbn.map do |book|
        {
          image: book[:image_url],
          title: book[:title],
          author: book[:author] || 'Unknown Author'
        }
      end
    }
  ]
%>

<%= render('_tabbed_availability_results', locals: {header: header, tabs: tabs}) %>
