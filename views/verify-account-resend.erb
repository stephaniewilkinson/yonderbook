<% content_for :title, "Resend Verification" %>
<% content_for :description, "Resend your Yonderbook account verification email." %>

<div class="max-w-md mx-auto">
  <div class="text-center mb-8">
    <h1 class="font-display text-3xl sm:text-4xl font-medium tracking-tight text-mauve-950 mb-3">
      Resend Verification Email
    </h1>
    <p class="text-lg text-mauve-700">
      If you no longer have the email to verify your account, enter your email address below to receive a new verification link
    </p>
  </div>

  <% if rodauth.field_error('login') %>
    <div class="bg-mauve-950/[.025] border border-mauve-300 text-mauve-950 px-4 py-3 rounded-xl mb-4">
      <p class="text-sm"><%= rodauth.field_error('login') %></p>
    </div>
  <% end %>

  <form method="post" action="<%= rodauth.verify_account_resend_path %>" class="space-y-4">
    <%= csrf_tag(rodauth.verify_account_resend_path) %>

    <div>
      <label for="login" class="block text-sm font-medium text-mauve-950 mb-1">
        Email
      </label>
      <input type="email"
             name="login"
             id="login"
             value="<%= rodauth.param('login') || rodauth.param('email') %>"
             autocomplete="email"
             class="w-full px-4 py-2 border border-mauve-300 rounded-xl bg-white focus:ring-2 focus:ring-mauve-500 focus:border-mauve-500 transition-all duration-200"
             required>
    </div>

    <div class="pt-2">
      <button type="submit" class="w-full inline-flex items-center justify-center px-6 py-3 bg-mauve-950 text-white font-medium text-lg rounded-full hover:bg-mauve-900 transition-colors duration-200">
        Send Verification Email Again
      </button>
    </div>
  </form>

  <div class="mt-6 text-center">
    <p class="text-sm text-mauve-700">
      Already verified?
      <a href="<%= rodauth.login_path %>" class="text-mauve-950 font-medium hover:underline">
        Log in
      </a>
    </p>
  </div>
</div>
